# ElevenLabs API Configuration
# Get your API key from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_api_key_here

# Optional: Custom voice ID
# Defaults in code to KLoixBflzS2a9rg6nT8x (see netlify/functions/speak.js)
# ELEVENLABS_VOICE_ID=KLoixBflzS2a9rg6nT8x

# --- TTS function abuse protection (all optional) ---------------------------
# Comma-separated list of origins allowed to call the TTS function.
# If unset, the function falls back to Netlify's deploy URLs + localhost dev.
# ALLOWED_ORIGINS=https://your-site.netlify.app

# Per-IP rate limit for the TTS function (best-effort, per warm container).
# TTS_RATE_LIMIT_MAX=30
# TTS_RATE_LIMIT_WINDOW_MS=60000
