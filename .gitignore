# Environment variables (contains API keys)
.env
.env.local
.env.production

# Dependencies
node_modules/

# Python cache (from scripts/)
__pycache__/
*.pyc

# Build outputs
.netlify/
dist/

# IDE
.vscode/
.idea/
.claude/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

