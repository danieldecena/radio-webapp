# Generated show files (build outputs from build_shows.py: mp3 + cue + data.js + manifest)
public/shows/
preview/*.mp3
public/music_locked/
public/music_locked_*/

# Logs
*.log
npm-debug.log*
.vercel

# Graphify generated output (knowledge graph cache + reports)
graphify-out/
q
