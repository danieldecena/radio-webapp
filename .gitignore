# Environment variables (contains API keys)
.env
.env.local
.env.production

# Dependencies
node_modules/

# Python cache (from scripts/)
__pycache__/
*.pyc

# Build outputs
.netlify/
dist/

# IDE
.vscode/
.idea/
.claude/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Local music files (large MP3s — tracked via playlist.json)
public/music/*.mp3

# Generated show files (build outputs from build_shows.py: mp3 + cue + data.js + manifest)
public/shows/
preview/*.mp3
public/music_locked/
public/music_locked_*/

# Logs
*.log
npm-debug.log*
.vercel

# Graphify generated output (knowledge graph cache + reports)
graphify-out/

# Archived standalone preview render (12MB build artifact)
docs/archive/preview_show.mp3

# Productivity system (local workspace, not part of the radio app)
dashboard.html
memory/

# Player redesign backups (local revert points)
public/*.bak

# Manual deploy artifact (rebuild by zipping public/)
rom-radio-deploy.zip

# --- OpenWolf scaffolding (commit the brain, ignore generated/volatile) ---
graphify-out/
.wolf/anatomy.md
.wolf/memory.md
.wolf/daemon.log
.wolf/cron-state.json
.wolf/token-ledger.json
.wolf/suggestions.json
.wolf/designqc-report.json
.wolf/hooks/_session.json

# Voiced DJ break audio (generated by generate_dj_breaks.js; baked into broadcast.mp3)
public/audio/breaks/*.mp3
public/audio/breaks/**/*.mp3

# HyperFrames birthday video (regenerable; shipped in the bundle)
public/gift/*.mp4

public/birthday.mp4
